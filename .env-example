# Example .env for mongo_backup_manager.sh — copy to `.env` beside the script and
# fill in real values. `.env` is gitignored; NEVER commit real secrets.
#   cp .env-example .env && $EDITOR .env

# --- MongoDB / container (required) ------------------------------------------
# CONTAINER_NAME may be either the EXACT container name OR a stable name PREFIX.
# A prefix is resolved at run time (via `docker ps`) to the single running match,
# which survives Coolify redeploys that regenerate the name's hash/timestamp
# suffix (e.g. sodax-stateful-mongo-<stackhash>-<timestamp>). It must resolve to
# exactly one running container — 0 or >1 matches is a hard error.
CONTAINER_NAME="sodax-stateful-mongo"
MONGO_PORT="27017"
MONGO_DB_NAME="test"

# --- MongoDB credentials (required unless USE_CREDENTIALS=false) --------------
USE_CREDENTIALS="true"   # set to "false" if the DB has no auth
MONGO_USER="user"
MONGO_PASSWORD="password"

# --- TLS (required only when the mongod runs net.tls.mode=requireTLS) ---------
# When true, mongodump/mongorestore/mongosh connect over TLS. Set this whenever the
# target mongod requires TLS — a plaintext client is otherwise rejected mid-handshake
# ("socket was unexpectedly closed: EOF" / "server selection timeout").
USE_TLS="false"
# Paths are INSIDE the container (the tools run via `docker exec`), so the files must
# exist in the container (bake into the image or bind-mount them). Both optional:
MONGO_TLS_CA_FILE=""         # CA .pem to validate the server cert (e.g. /etc/ssl/mongo/ca.pem)
MONGO_TLS_CERT_KEY_FILE=""   # client cert+key .pem, only if the server requires client certs
# Skip server cert-chain + hostname validation. Usually needed here because the tools
# connect to `localhost` inside the container, whose cert has no `localhost` SAN (and
# self-signed certs won't validate). The connection stays encrypted, just unauthenticated.
# Prefer MONGO_TLS_CA_FILE when the CA is available. mongodump/mongorestore get
# --tlsInsecure; mongosh gets --tlsAllowInvalidCertificates --tlsAllowInvalidHostnames.
MONGO_TLS_ALLOW_INVALID="false"

# --- S3 remote (required only when USE_REMOTE=true) --------------------------
USE_REMOTE="false"       # set to "true" to enable S3 upload/download/list/prune
S3_BUCKET_NAME="name-of-your-s3-bucket"
AWS_PROFILE="admin"
# Days after which S3 backups are pruned (default 7). 0 = skip the tool's S3
# prune and let an S3 lifecycle rule own retention. Non-negative integer.
S3_RETENTION_DAYS="7"

# --- Failure alerting (required only when USE_ALERTS=true) -------------------
# When true, a failed scheduled backup (see systemd/mongo-backup-alert.service)
# posts the run's journal tail to whichever destinations you configure below.
# Configure Discord, Telegram, or both. A half-configured Telegram (only one of
# the two vars) is rejected by health_check.
USE_ALERTS="false"
DISCORD_WEBHOOK_URL=""   # e.g. https://discord.com/api/webhooks/<id>/<token>
TELEGRAM_BOT_TOKEN=""    # e.g. 123456:AA... (from @BotFather)
TELEGRAM_CHAT_ID=""      # e.g. -1001234567890 (channel/chat id)
